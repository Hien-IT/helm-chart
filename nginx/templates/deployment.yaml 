apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ .Release.Name }}-nginx-ingress
  labels:
    app: nginx-ingress
spec:
  replicas: {{ .Values.replicaCount }}
  selector:
    matchLabels:
      app: nginx-ingress
  template:
    metadata:
      labels:
        app: nginx-ingress
    spec:
      serviceAccountName: {{ .Release.Name }}-nginx-ingress
      containers:
      - name: nginx-ingress
        image: "{{ .Values.image.repository }}:{{ .Values.image.tag }}"
        args:
          - -nginx-configmaps=$(POD_NAMESPACE)/{{ .Release.Name }}-nginx-configmap
        env:
          - name: POD_NAMESPACE
            valueFrom:
              fieldRef:
                fieldPath: metadata.namespace
          - name: POD_NAME
            valueFrom:
              fieldRef:
                fieldPath: metadata.name
        ports:
        - name: http
          containerPort: 80
        - name: https
          containerPort: 443